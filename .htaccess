# Configuration pour application Angular
# Définir index.html comme fichier index par défaut (fallback vers index.csr.html)
DirectoryIndex index.html index.csr.html

# Activer le module de réécriture
<IfModule mod_rewrite.c>
  RewriteEngine On
  
  # Si le fichier ou répertoire demandé existe, servir directement
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  
  # Rediriger toutes les autres requêtes vers index.html (ou index.csr.html) pour le routing Angular
  RewriteRule ^ index.html [L]
</IfModule>

# Désactiver l'affichage des listings de répertoires
Options -Indexes

# Configuration des types MIME
<IfModule mod_mime.c>
  AddType application/javascript js
  AddType text/css css
</IfModule>

# Cache pour les assets statiques
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType application/pdf "access plus 1 month"
</IfModule>

